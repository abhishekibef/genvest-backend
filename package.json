{
  "name": "genz-trading-backend",
  "version": "1.0.0",
  "description": "Gen Z Trading Platform Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "npx prisma generate && npx prisma db push && node server.js",
    "db:init": "npx prisma db push && npx prisma db seed",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
