datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  username         String?       @unique
  name             String?
  phone            String?
  password         String?
  twoFactorEnabled Boolean       @default(false)
  cash             Float         @default(1000000.0)
  streak           Int           @default(1)
  lastActive       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  totalXP          Int           @default(0)
  gems             Int           @default(100)
  tourCompleted    Boolean       @default(false)
  startOfDayNetWorth Float       @default(1000000.0)
  holdings         Holding[]
  transactions     Transaction[]
  lessons          UserLesson[]

  // Referral System
  referralCode     String?       @unique
  referredById     Int?
  referredBy       User?         @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]        @relation("UserReferrals")

  // Tournament System
  tournamentEntries      TournamentEntry[]
  tournamentTransactions TournamentTransaction[]

  // Private Lobby System
  hostedLobbies          PrivateLobby[]         @relation("HostedLobbies")
  lobbyEntries           PrivateLobbyEntry[]
  lobbyTransactions      PrivateLobbyTransaction[]

  // Gamification & Leagues
  league                 String                 @default("BRONZE")
  highestLeague          String                 @default("BRONZE")
  socialFeeds            SocialFeed[]
}


model Stock {
  id                 String              @id
  name               String
  sector             String
  price              Float
  prevPrice          Float
  volatility         String              // "HIGH", "MEDIUM", "LOW"
  description        String
  reason             String              // Today's movement context
  holdings           Holding[]
  transactions       Transaction[]
  competitorHoldings CompetitorHolding[]
  tournamentHoldings TournamentHolding[]
  tournamentTransactions TournamentTransaction[]

  // Private Lobby System
  lobbyHoldings          PrivateLobbyHolding[]
  lobbyTransactions      PrivateLobbyTransaction[]
}

model Holding {
  id        Int    @id @default(autoincrement())
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  stock     Stock  @relation(fields: [stockId], references: [id])
  stockId   String
  quantity  Int
  avgPrice  Float

  @@unique([userId, stockId])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  stock     Stock    @relation(fields: [stockId], references: [id])
  stockId   String
  type      String   // "BUY" or "SELL"
  quantity  Int
  price     Float
  timestamp DateTime @default(now())
}

model Competitor {
  id        Int                 @id @default(autoincrement())
  username  String              @unique
  avatar    String              // Avatar background color or short label
  cash      Float               @default(1000000.0)
  streak    Int                 @default(5)
  holdings  CompetitorHolding[]
}

model CompetitorHolding {
  id           Int        @id @default(autoincrement())
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  competitorId Int
  stock        Stock      @relation(fields: [stockId], references: [id])
  stockId      String
  quantity     Int
  avgPrice     Float

  @@unique([competitorId, stockId])
}

// ========================
// LEARNING SYSTEM MODELS
// ========================

model Level {
  id          Int      @id @default(autoincrement())
  number      Int      @unique
  title       String
  description String
  icon        String
  lessons     Lesson[]
}

model Lesson {
  id                String       @id
  levelId           Int
  level             Level        @relation(fields: [levelId], references: [id])
  lessonNumber      Int
  title             String
  readTime          String
  xpReward          Int          @default(20)
  learningObjective String       @default("")
  hook              String       @default("")
  story             String       @default("")
  visualSuggestion  String       @default("")
  coreExplanation   String       @default("")
  didYouKnow        String       @default("")
  indianExample     String       @default("")
  interactiveHint   String       @default("")
  memoryTrick       String       @default("")
  recap             String       @default("[]")
  unlockMessage     String       @default("")
  quiz              String       @default("[]")
  userLessons       UserLesson[]

  @@unique([levelId, lessonNumber])
}

model UserLesson {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  completed Boolean  @default(true)
  score     Int      @default(0)
  xpEarned  Int      @default(0)
  attempts  Int      @default(1)
  timestamp DateTime @default(now())

  @@unique([userId, lessonId])
}

// ========================
// TOURNAMENT SYSTEM MODELS
// ========================

model Tournament {
  id        Int      @id @default(autoincrement())
  date      String   @unique // Format: "YYYY-MM-DD"
  status    String   @default("ACTIVE") // "ACTIVE", "COMPLETED"
  createdAt DateTime @default(now())
  
  entries      TournamentEntry[]
  transactions TournamentTransaction[]
}

model TournamentEntry {
  id            Int        @id @default(autoincrement())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId  Int
  
  startingCash  Float      @default(1000000.0)
  currentCash   Float      @default(1000000.0)
  profit        Float      @default(0.0)
  joinedAt      DateTime   @default(now())

  holdings      TournamentHolding[]

  @@unique([userId, tournamentId])
}

model TournamentHolding {
  id               Int             @id @default(autoincrement())
  entry            TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId          Int
  stock            Stock           @relation(fields: [stockId], references: [id])
  stockId          String
  quantity         Int
  avgPrice         Float

  @@unique([entryId, stockId])
}

model TournamentTransaction {
  id            Int        @id @default(autoincrement())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId  Int
  stock         Stock      @relation(fields: [stockId], references: [id])
  stockId       String
  type          String     // "BUY" or "SELL"
  quantity      Int
  price         Float
  timestamp     DateTime   @default(now())
}

// ========================
// PRIVATE LOBBY MODELS
// ========================

model PrivateLobby {
  id            Int                    @id @default(autoincrement())
  code          String                 @unique // e.g. IITB98
  name          String
  hostId        Int
  startingCash  Float                  @default(1000000.0)
  status        String                 @default("ACTIVE") // "ACTIVE", "COMPLETED"
  startTime     DateTime
  endTime       DateTime
  restrictNifty50 Boolean              @default(true)
  isPublic        Boolean              @default(false)
  maxParticipants Int?
  isRecurring     Boolean              @default(false)
  createdAt     DateTime               @default(now())
  
  host          User                   @relation("HostedLobbies", fields: [hostId], references: [id], onDelete: Cascade)
  entries       PrivateLobbyEntry[]
  transactions  PrivateLobbyTransaction[]
}

model PrivateLobbyEntry {
  id           Int                     @id @default(autoincrement())
  lobbyId      Int
  userId       Int
  startingCash Float                   @default(1000000.0)
  currentCash  Float                   @default(1000000.0)
  profit       Float                   @default(0.0)
  joinedAt     DateTime                @default(now())
  
  lobby        PrivateLobby            @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     PrivateLobbyHolding[]
  
  @@unique([userId, lobbyId])
}

model PrivateLobbyHolding {
  id           Int                 @id @default(autoincrement())
  entryId      Int
  stockId      String
  quantity     Int
  avgPrice     Float
  
  entry        PrivateLobbyEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  stock        Stock               @relation(fields: [stockId], references: [id])
  
  @@unique([entryId, stockId])
}

model PrivateLobbyTransaction {
  id            Int                 @id @default(autoincrement())
  lobbyId       Int
  userId        Int
  stockId       String
  type          String              // "BUY" or "SELL"
  quantity      Int
  price         Float
  timestamp     DateTime            @default(now())
  
  lobby         PrivateLobby        @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock         Stock               @relation(fields: [stockId], references: [id])
}

// ========================
// SOCIAL FEED MODELS
// ========================

model SocialFeed {
  id        Int      @id @default(autoincrement())
  userId    Int
  username  String
  type      String   // "TRADE", "STREAK", "PROMOTION"
  message   String
  timestamp DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
